# ─────────────────────────────────────────────────────────────────────
# SmartEssentials Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://smartessentials.vercel.app

# ── Admin ────────────────────────────────────────────────────────────
# ADMIN_SECRET is SERVER-ONLY (no NEXT_PUBLIC_ prefix) — never exposed to browser.
# This is the password you type at /admin/login.
# Set to any long, random string. Example: openssl rand -base64 32
ADMIN_SECRET=replace_with_a_long_random_secret_minimum_32_chars

# SESSION_TOKEN_SECRET — used to sign session cookies. Keep this secret and random.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_TOKEN_SECRET=replace_with_another_long_random_secret

# ── Firebase ─────────────────────────────────────────────────────────
# Setup: console.firebase.google.com → New Project → Web App → Copy config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Supabase — REQUIRED (primary database) ───────────────────────────
# Setup: supabase.com → New Project → Settings → API
# These are safe to expose to the browser (they respect RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to browser.
# Used in admin API routes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Analytics 4 ───────────────────────────────────────────────
# Setup: analytics.google.com → Create Property → Web → Measurement ID
# After adding your ID, uncomment the GA4 scripts in src/app/layout.tsx
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Amazon Associates ─────────────────────────────────────────────────
# Your tracking tag from affiliate-program.amazon.in
# Replace every "YOURTAG-21" in src/data/products.json with this value
NEXT_PUBLIC_AMAZON_TAG=YOURTAG-21

# ── Newsletter ────────────────────────────────────────────────────────
# Option A — Mailchimp
MAILCHIMP_API_KEY=your-api-key-usXX
MAILCHIMP_LIST_ID=your-list-id

# Option B — ConvertKit
CONVERTKIT_API_KEY=your-api-key
CONVERTKIT_FORM_ID=your-form-id

# Option C — Resend (for transactional email / contact form)
RESEND_API_KEY=re_xxxxxxxx
